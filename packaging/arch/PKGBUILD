pkgname=deepcool-desktop
pkgver=0.1.0
pkgrel=1
pkgdesc="Deepcool Digital Linux GUI for Deepcool Digital devices"
arch=('x86_64')
url="https://example"
license=('GPL')
depends=(gtk3 hidapi)
source=("$pkgname-$pkgver.tar.gz")
install=$pkgname.install

build() {
  cd "$srcdir/$pkgname-$pkgver/flutter_desktop"
  if [[ -x build/linux/x64/release/bundle/deepcool_desktop_app ]]; then
    echo "Using prebuilt Flutter release bundle from source tarball."
  elif command -v flutter >/dev/null 2>&1; then
    flutter build linux --release
  else
    echo "Flutter release bundle is missing and flutter is not installed." >&2
    return 1
  fi

  if [[ ! -x "$srcdir/$pkgname-$pkgver/build/deepcool-digital-dart" ]]; then
    echo "CLI daemon binary is missing from the source tarball." >&2
    return 1
  fi
}

package() {
  cd "$srcdir/$pkgname-$pkgver"

  # Install full Flutter Linux bundle
  install -dm755 "$pkgdir/usr/lib/deepcool-desktop"
  cp -a flutter-bundle/. "$pkgdir/usr/lib/deepcool-desktop/"

  # GUI launcher wrapper
  install -dm755 "$pkgdir/usr/bin"

  cat > "$pkgdir/usr/bin/deepcool-desktop" <<'EOF'
#!/usr/bin/env bash
set -e
APPDIR="/usr/lib/deepcool-desktop"
export LD_LIBRARY_PATH="$APPDIR/lib:${LD_LIBRARY_PATH:-}"
exec "$APPDIR/deepcool_desktop_app" "$@"
EOF

  chmod 755 "$pkgdir/usr/bin/deepcool-desktop"

  # CLI daemon
  install -Dm755 build/deepcool-digital-dart "$pkgdir/usr/bin/deepcool-digital-dart"

  # udev rule
  install -Dm644 udev/99-deepcool-digital.rules \
    "$pkgdir/etc/udev/rules.d/99-deepcool-digital.rules"

  # systemd files, only if you have them
  if [ -d systemd ]; then
    install -dm755 "$pkgdir/usr/lib/systemd/system"
    cp -a systemd/*.service "$pkgdir/usr/lib/systemd/system/" 2>/dev/null || true
  fi

  # Desktop file and icon should stay wherever your current PKGBUILD already installs them
}