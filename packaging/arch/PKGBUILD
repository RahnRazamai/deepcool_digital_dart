pkgname=deepcool-desktop
pkgver=0.1.0
pkgrel=1
pkgdesc="Deepcool Digital Linux GUI for Deepcool Digital devices"
arch=('x86_64')
url="https://github.com/Nortank12/deepcool_digital_dart"
license=('GPL')
depends=('gtk3' 'hidapi')
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')
install="${pkgname}.install"
options=('!strip')

package() {
  cd "$srcdir/${pkgname}-${pkgver}"

  # Install full Flutter Linux bundle
  install -dm755 "$pkgdir/usr/lib/${pkgname}"
  cp -a flutter-bundle/. "$pkgdir/usr/lib/${pkgname}/"

  chmod +x "$pkgdir/usr/lib/${pkgname}/deepcool_desktop_app"

  # GUI launcher wrapper
  install -Dm755 /dev/stdin "$pkgdir/usr/bin/deepcool-desktop" <<'EOF'
#!/usr/bin/env bash
set -e

APPDIR="/usr/lib/deepcool-desktop"

cd "$APPDIR"
export LD_LIBRARY_PATH="$APPDIR/lib:${LD_LIBRARY_PATH:-}"

exec "$APPDIR/deepcool_desktop_app" "$@"
EOF

  # CLI daemon
  install -Dm755 build/deepcool-digital-dart "$pkgdir/usr/bin/deepcool-digital-dart"

  # udev rule
  if [ -f udev/99-deepcool-digital.rules ]; then
    install -Dm644 udev/99-deepcool-digital.rules \
      "$pkgdir/usr/lib/udev/rules.d/99-deepcool-digital.rules"
  fi

  # desktop file
  if compgen -G "applications/*.desktop" > /dev/null; then
    install -dm755 "$pkgdir/usr/share/applications"
    install -Dm644 applications/*.desktop -t "$pkgdir/usr/share/applications/"
  fi

  # icons
  if [ -d icons ]; then
    cp -a icons/. "$pkgdir/usr/share/icons/"
  fi
}
